  <sys:String x:Key="BtnOpen">Open</sys:String>
  <!-- Detail view -->
  <sys:String x:Key="Back">Back</sys:String>
  <sys:String x:Key="EditBtn">Edit</sys:String>
  <sys:String x:Key="Developer">Developer</sys:String>
  <sys:String x:Key="Version">Version</sys:String>
  <sys:String x:Key="Country">Country</sys:String>
  <sys:String x:Key="Price">Price</sys:String>
  <sys:String x:Key="Tags">Tags</sys:String>
  <sys:String x:Key="Description">Description</sys:String>
  <!-- Filter popup -->
  <sys:String x:Key="SortBy">Sort by</sys:String>
  <sys:String x:Key="SortFeatured">Featured</sys:String>
  <sys:String x:Key="SortRating">Rating ↓</sys:String>
  <sys:String x:Key="SortPriceAsc">Price ↑</sys:String>
  <sys:String x:Key="SortPriceDesc">Price ↓</sys:String>
  <sys:String x:Key="SortDownloads">Downloads</sys:String>
  <sys:String x:Key="SortNewest">Newest</sys:String>
  <sys:String x:Key="SortName">Name A→Z</sys:String>
  <sys:String x:Key="MinRating">Min Rating</sys:String>
  <sys:String x:Key="PriceRange">Price Range</sys:String>
  <sys:String x:Key="DownloadedOnly">Downloaded only</sys:String>
  <sys:String x:Key="ResetFilters">Reset Filters</sys:String>
  <sys:String x:Key="RestoreData">Restore Default Apps</sys:String>
  <!-- Form -->
  <sys:String x:Key="ShortName">Short Name</sys:String>
  <sys:String x:Key="FullName">Full Name</sys:String>
  <sys:String x:Key="Category">Category</sys:String>
  <sys:String x:Key="Rating">Rating</sys:String>
  <sys:String x:Key="AgeRating">Age Rating</sys:String>
  <sys:String x:Key="Discount">Discount %</sys:String>
  <sys:String x:Key="InStock">In Stock</sys:String>
  <sys:String x:Key="Cancel">Cancel</sys:String>
  <sys:String x:Key="Save">Save</sys:String>
  <!-- Dialogs -->
  <sys:String x:Key="EditAppTitle">Edit App</sys:String>
  <sys:String x:Key="DeleteAppTitle">Delete App</sys:String>
  <sys:String x:Key="DeleteConfirmTitle">Delete App?</sys:String>
  <sys:String x:Key="DeleteConfirmMsg"
  >This action cannot be undone. The app will be permanently
    removed.</sys:String>
  <sys:String x:Key="DeleteBtn">Delete</sys:String>
  <sys:String x:Key="RestoreConfirmTitle">Restore Defaults?</sys:String>
  <sys:String x:Key="RestoreConfirmMsg"
  >This will replace all apps with the original 12 seed apps.</sys:String>
  <sys:String x:Key="RestoreBtn">Restore</sys:String>
  <!-- Empty state -->
  <sys:String x:Key="NoAppsFound">No Apps Found</sys:String>
  <sys:String x:Key="NoAppsHint">Try adjusting your filters or search query</sys:String>
  <!-- Stats -->
  <sys:String x:Key="AppsInStore">apps in store</sys:String>
  <sys:String x:Key="AppsInstalled">installed</sys:String>
  <!-- Auth -->
  <sys:String x:Key="LoginSubtitle">Sign in to your account</sys:String>
  <sys:String x:Key="LoginLabel">Login</sys:String>
  <sys:String x:Key="PasswordLabel">Password</sys:String>
  <sys:String x:Key="SignIn">Sign In</sys:String>
  <sys:String x:Key="LoginHint">admin / admin or user / 1234</sys:String>
  <sys:String x:Key="LoginError">Invalid login or password</sys:String>
  <sys:String x:Key="Logout">Log Out</sys:String>
  <!-- Profile -->
  <sys:String x:Key="ProfileEditTitle">Profile</sys:String>
  <sys:String x:Key="LabelFirstName">First Name</sys:String>
  <sys:String x:Key="LabelLastName">Last Name</sys:String>
  <sys:String x:Key="LabelEmail">Email</sys:String>
  <sys:String x:Key="PlaceholderFirstName">Enter first name</sys:String>
  <sys:String x:Key="PlaceholderLastName">Enter last name</sys:String>
  <sys:String x:Key="PlaceholderEmail">Enter email</sys:String>
  <sys:String x:Key="SaveProfile">Save Profile</sys:String>
  <sys:String x:Key="ChangePasswordTitle">Change Password</sys:String>
  <sys:String x:Key="LabelOldPassword">Current Password</sys:String>
  <sys:String x:Key="LabelNewPassword">New Password</sys:String>
  <sys:String x:Key="ChangePassword">Change Password</sys:String>
  <sys:String x:Key="DarkModeLabel">Dark Mode</sys:String>
  <sys:String x:Key="DarkModeHint">Switch app appearance</sys:String>
</ResourceDictionary>