<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
>
  <!-- General -->
  <sys:String x:Key="AppTitle">App Store</sys:String>
  <sys:String x:Key="CurrentLanguage">en</sys:String>
  <!-- Sidebar categories -->
  <sys:String x:Key="CatDiscover">Discover</sys:String>
  <sys:String x:Key="CatCreate">Create</sys:String>
  <sys:String x:Key="CatWork">Work</sys:String>
  <sys:String x:Key="CatPlay">Play</sys:String>
  <sys:String x:Key="CatDevelop">Develop</sys:String>
  <sys:String x:Key="CatCategories">Categories</sys:String>
  <sys:String x:Key="CatInstalled">Installed</sys:String>
  <!-- Section headers -->
  <sys:String x:Key="TopApps">Top Apps</sys:String>
  <sys:String x:Key="SeeAll">See All</sys:String>
  <sys:String x:Key="Filters">Filters</sys:String>
  <sys:String x:Key="AddApp">+ Add App</sys:String>
  <sys:String x:Key="EditApp">Edit App</sys:String>
  <!-- Featured banner -->
  <sys:String x:Key="FeaturedToday">FEATURED TODAY</sys:String>
  <sys:String x:Key="Download">Download</sys:String>
  <!-- App detail tiles -->
  <sys:String x:Key="TileRatings">Ratings</sys:String>
  <sys:String x:Key="TileAge">Age</sys:String>
  <sys:String x:Key="TileYears">Years</sys:String>
  <sys:String x:Key="TileDev">Developer</sys:String>
  <sys:String x:Key="TileDevLabel">Developer</sys:String>
  <sys:String x:Key="TileLang">Language</sys:String>
  <sys:String x:Key="TileSize">Size</sys:String>
