<Application
  x:Class="Project.ApplicationApp"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:converters="clr-namespace:Project.Converters"
>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/Styles/LightAppTheme.xaml" />
        <ResourceDictionary Source="Resources/Localization/en.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <Style TargetType="{x:Type Window}">
        <Setter Property="Icon" Value="pack://application:,,,/Resources/Icons/app.ico" />
        <Setter Property="Cursor" Value="Arrow" />
      </Style>
      <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
      <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
      <converters:NullToVisibilityConverter x:Key="NullToVis" />
      <converters:PriceConverter x:Key="PriceConv" />
      <converters:DownloadCountConverter x:Key="DlCountConv" />
      <converters:RatingToStarsConverter x:Key="RatingStars" />
      <converters:SizeConverter x:Key="SizeConv" />
      <converters:StringToColorBrushConverter x:Key="ColorBrush" />
      <converters:DiscountVisibilityConverter x:Key="DiscountVis" />
      <converters:RoleNameConverter x:Key="RoleNameConv" />
      <converters:ButtonLabelConverter x:Key="ButtonLabelConv" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
