<Window
  x:Class="Project.Views.LoginWindow"
  Icon="pack://application:,,,/Resources/Icons/app.ico"
  Cursor="pack://application:,,,/Resources/Cursors/arrow.cur"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="White"
  FontFamily="Segoe UI"
  Width="380"
  SizeToContent="Height"
  WindowStartupLocation="CenterScreen"
  ResizeMode="CanResize"
>
  <Border CornerRadius="16" Background="White">
    <Border.Effect>
      <DropShadowEffect ShadowDepth="0" BlurRadius="40" Opacity="0.18" Color="#000000" />
    </Border.Effect>
    <StackPanel Margin="32,32,32,28">
      <!-- Logo -->
      <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
        <Border
          Width="56"
          Height="56"
          CornerRadius="14"
          HorizontalAlignment="Center"
          Margin="0,0,0,12"
        >
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#0072F7" Offset="0" />
              <GradientStop Color="#34AADC" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <TextBlock
            Text="A"
            FontSize="28"
            FontWeight="Bold"
            Foreground="White"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
          />
        </Border>
        <TextBlock
          Text="App Store"
          FontSize="20"
          FontWeight="Bold"
          Foreground="#272727"
          HorizontalAlignment="Center"
        />
        <TextBlock
          Text="{DynamicResource LoginSubtitle}"
          FontSize="13"
          Foreground="#828282"
          HorizontalAlignment="Center"
          Margin="0,4,0,0"
        />
      </StackPanel>
      <!-- Error message -->
      <Border
        x:Name="ErrorBorder"
        Background="#FFF0F0"
        CornerRadius="8"
        Padding="12,8"
        Margin="0,0,0,14"
        Visibility="Collapsed"
      >
        <TextBlock x:Name="ErrorText" FontSize="13" Foreground="#FF3B30" TextWrapping="Wrap" />
      </Border>
      <!-- Login field -->
      <TextBlock
        Text="{DynamicResource LoginLabel}"
        FontSize="12"
        Foreground="#828282"
        Margin="0,0,0,4"
      />
      <Border
        Background="#F7F7F8"
        CornerRadius="10"
        BorderThickness="1.5"
        BorderBrush="#E6E6E6"
        Margin="0,0,0,14"
        x:Name="LoginFieldBorder"
      >
        <TextBox
          x:Name="LoginBox"
          Background="Transparent"
          BorderThickness="0"
          FontSize="14"
          Foreground="#272727"
          Padding="12,10"
          CaretBrush="#0072F7"
          GotFocus="OnFieldFocus"
          LostFocus="OnFieldBlur"
          KeyDown="OnKeyDown"
        >
          <TextBox.Template>
            <ControlTemplate TargetType="TextBox">
              <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
            </ControlTemplate>
          </TextBox.Template>
        </TextBox>
      </Border>
      <!-- Password field -->
      <TextBlock
        Text="{DynamicResource PasswordLabel}"
        FontSize="12"
        Foreground="#828282"
        Margin="0,0,0,4"
      />
      <Border
        Background="#F7F7F8"
        CornerRadius="10"
        BorderThickness="1.5"
        BorderBrush="#E6E6E6"
        Margin="0,0,0,24"
        x:Name="PassFieldBorder"
      >
        <PasswordBox
          x:Name="PassBox"
          Background="Transparent"
          BorderThickness="0"
          FontSize="14"
          Foreground="#272727"
          Padding="12,10"
          CaretBrush="#0072F7"
          GotFocus="OnFieldFocus"
          LostFocus="OnFieldBlur"
          KeyDown="OnKeyDown"
        >
          <PasswordBox.Template>
            <ControlTemplate TargetType="PasswordBox">
              <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
            </ControlTemplate>
          </PasswordBox.Template>
        </PasswordBox>
      </Border>
      <!-- Sign in button -->
      <Button
        x:Name="SignInBtn"
        Click="OnSignIn"
        IsDefault="True"
        Height="44"
        FontSize="15"
        FontWeight="SemiBold"
        Foreground="White"
        BorderThickness="0"
        Cursor="Hand"
      >
        <Button.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0072F7" Offset="0" />
            <GradientStop Color="#34AADC" Offset="1" />
          </LinearGradientBrush>
        </Button.Background>
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border
              Background="{TemplateBinding Background}"
              CornerRadius="12"
              Padding="{TemplateBinding Padding}"
            >
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.88" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Opacity" Value="0.75" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Button.Template>
        <TextBlock Text="{DynamicResource SignIn}" />
      </Button>
      <!-- Hint -->
      <TextBlock
        Margin="0,14,0,0"
        HorizontalAlignment="Center"
        FontSize="11"
        Foreground="#BDBDBD"
        Text="{DynamicResource LoginHint}"
      />
    </StackPanel>
  </Border>
</Window>
