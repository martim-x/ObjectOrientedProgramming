<UserControl
  x:Class="Project.Views.AppCardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Width="176"
>
  <Border Style="{StaticResource AppRowStyle}" Padding="14" MouseLeftButtonUp="OnCardClick">
    <Border.Effect>
      <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.3" Color="Black" />
    </Border.Effect>
    <StackPanel>
      <!-- Icon -->
      <Grid HorizontalAlignment="Center" Margin="0,0,0,10">
        <Border
          Width="80"
          Height="80"
          CornerRadius="18"
          ClipToBounds="True"
          Background="{Binding Color, Converter={StaticResource ColorBrush}}"
        >
          <TextBlock
            Text="{Binding ShortName}"
            FontSize="16"
            FontWeight="Bold"
            Foreground="White"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MaxWidth="72"
            TextTrimming="CharacterEllipsis"
            TextAlignment="Center"
          />
        </Border>
        <!-- Discount badge -->
        <Border
          HorizontalAlignment="Right"
          VerticalAlignment="Top"
          Background="{StaticResource OrangeBrush}"
          CornerRadius="8"
          Padding="5,2"
          Margin="0,4,4,0"
          Visibility="{Binding DiscountPercent, Converter={StaticResource DiscountVis}}"
        >
          <TextBlock
            FontSize="9"
            FontWeight="Bold"
            Foreground="White"
            Text="{Binding DiscountPercent, StringFormat=-{0:F0}%}"
          />
        </Border>
        <!-- Downloaded checkmark -->
        <Border
          HorizontalAlignment="Left"
          VerticalAlignment="Top"
          Background="{StaticResource GreenBrush}"
          CornerRadius="8"
          Padding="5,2"
          Margin="4,4,0,0"
          Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVis}}"
        >
          <TextBlock Text="✓" FontSize="9" FontWeight="Bold" Foreground="White" />
        </Border>
      </Grid>
      <!-- Name -->
      <TextBlock
        Text="{Binding ShortName}"
        FontSize="13"
        FontWeight="SemiBold"
        Foreground="White"
        TextAlignment="Center"
        TextTrimming="CharacterEllipsis"
        Margin="0,0,0,2"
      />
      <!-- Developer -->
      <TextBlock
        Text="{Binding Developer}"
        FontSize="11"
        Foreground="{StaticResource TextSecondaryBrush}"
        TextAlignment="Center"
        TextTrimming="CharacterEllipsis"
        Margin="0,0,0,6"
      />
      <!-- Rating -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
        <TextBlock
          Text="{Binding Rating, Converter={StaticResource RatingStars}}"
          Foreground="{StaticResource OrangeBrush}"
          FontSize="10"
        />
        <TextBlock
          Text="{Binding RatingCount, Converter={StaticResource DlCountConv}}"
          Foreground="{StaticResource TextTertiaryBrush}"
          FontSize="10"
          Margin="4,0,0,0"
        />
      </StackPanel>
      <!-- Get/Open button — use ButtonLabel computed property -->
      <Button
        HorizontalAlignment="Center"
        Padding="16,5"
        Style="{StaticResource GetButtonStyle}"
        Command="{Binding DownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
        CommandParameter="{Binding}"
      >
        <Button.Content>
          <TextBlock Text="{Binding ButtonLabel}" Foreground="{StaticResource GetBtnTextBrush}" />
        </Button.Content>
      </Button>
    </StackPanel>
  </Border>
</UserControl>
