<Window
  x:Class="Project.Views.ProfilePopup"
  Icon="pack://application:,,,/Resources/Icons/app.ico"
  Cursor="pack://application:,,,/Resources/Cursors/arrow.cur"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
  FontFamily="Segoe UI"
  Width="300"
  SizeToContent="Height"
  ResizeMode="CanResize"
  ShowInTaskbar="False"
  Deactivated="OnDeactivated"
>
  <!--
        ProfilePopup.xaml — Updated version
        ─ Avatar + name + role badge
        ─ Separator
        ─ Editable profile fields (FirstName, LastName, Email) + Save button
        ─ Separator
        ─ Change Password section (OldPw, NewPw) + Change button
        ─ Separator
        ─ Dark Mode toggle row
        ─ Separator
        ─ Logout button

        All colors via DynamicResource so light/dark theme switch works at runtime.
    -->
  <Border CornerRadius="14" Background="{DynamicResource PopupBgBrush}" BorderThickness="0">
    <Border.Effect>
      <DropShadowEffect ShadowDepth="0" BlurRadius="28" Opacity="0.22" Color="#000000" />
    </Border.Effect>
    <StackPanel>
      <!-- ═══ Avatar + Name + Role ══════════════════════════ -->
      <StackPanel Margin="18,18,18,14" HorizontalAlignment="Center">
        <Border
          x:Name="AvatarBorder"
          Width="56"
          Height="56"
          CornerRadius="28"
          HorizontalAlignment="Center"
          Margin="0,0,0,10"
        >
          <TextBlock
            x:Name="AvatarLetter"
            FontSize="22"
            FontWeight="Bold"
            Foreground="White"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
          />
        </Border>
        <TextBlock
          x:Name="LoginText"
          FontSize="15"
          FontWeight="SemiBold"
          Foreground="{DynamicResource TitleTextBrush}"
          HorizontalAlignment="Center"
        />
        <Border
          x:Name="RoleBadge"
          CornerRadius="8"
          Padding="10,3"
          HorizontalAlignment="Center"
          Margin="0,6,0,0"
        >
          <TextBlock x:Name="RoleText" FontSize="11" FontWeight="SemiBold" Foreground="White" />
        </Border>
      </StackPanel>
      <!-- ── Separator ─────────────────────────────────────── -->
      <Border Height="1" Background="{DynamicResource SeparatorBrush}" />
      <!-- ═══ Editable Profile Fields ═══════════════════════ -->
      <StackPanel Margin="18,14,18,14">
        <TextBlock
          Text="{DynamicResource ProfileEditTitle}"
          FontSize="12"
          FontWeight="SemiBold"
          Foreground="{DynamicResource SecondaryTextBrush}"
          Margin="0,0,0,10"
        />
        <!-- First Name -->
        <TextBlock
          Text="{DynamicResource LabelFirstName}"
          FontSize="11"
          Foreground="{DynamicResource SecondaryTextBrush}"
          Margin="0,0,0,4"
        />
        <TextBox
          Style="{DynamicResource FormTextBoxStyle}"
          BorderBrush="{DynamicResource DividerBrush}"
          Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
          Tag="{DynamicResource PlaceholderFirstName}"
          Margin="0,0,0,10"
        />
        <!-- Last Name -->
        <TextBlock
          Text="{DynamicResource LabelLastName}"
          FontSize="11"
          Foreground="{DynamicResource SecondaryTextBrush}"
          Margin="0,0,0,4"
        />
        <TextBox
          Style="{DynamicResource FormTextBoxStyle}"
          BorderBrush="{DynamicResource DividerBrush}"
          Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
          Tag="{DynamicResource PlaceholderLastName}"
          Margin="0,0,0,10"
        />
        <!-- Email -->
        <TextBlock
          Text="{DynamicResource LabelEmail}"
          FontSize="11"
          Foreground="{DynamicResource SecondaryTextBrush}"
          Margin="0,0,0,4"
        />
        <TextBox
          Style="{DynamicResource FormTextBoxStyle}"
          BorderBrush="{DynamicResource DividerBrush}"
          Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
          Tag="{DynamicResource PlaceholderEmail}"
          Margin="0,0,0,14"
        />
        <!-- Save Profile button -->
        <Button
          Style="{DynamicResource PrimaryButtonStyle}"
          HorizontalAlignment="Stretch"
          Command="{Binding SaveProfileCommand}"
        >
          <TextBlock Text="{DynamicResource SaveProfile}" FontSize="13" />
        </Button>
      </StackPanel>
      <!-- ── Separator ─────────────────────────────────────── -->
      <Border Height="1" Background="{DynamicResource SeparatorBrush}" />
      <!-- ═══ Change Password Section ════════════════════════ -->
      <StackPanel Margin="18,14,18,14">
        <TextBlock
          Text="{DynamicResource ChangePasswordTitle}"
          FontSize="12"
          FontWeight="SemiBold"
          Foreground="{DynamicResource SecondaryTextBrush}"
          Margin="0,0,0,10"
        />
        <!-- Old Password -->
        <TextBlock
          Text="{DynamicResource LabelOldPassword}"
          FontSize="11"
          Foreground="{DynamicResource SecondaryTextBrush}"
          Margin="0,0,0,4"
        />
        <Border
          x:Name="OldPwBorder"
          Background="{DynamicResource InfoCardBgBrush}"
          CornerRadius="10"
          BorderThickness="1.5"
          BorderBrush="{DynamicResource DividerBrush}"
          Margin="0,0,0,10"
        >
          <PasswordBox
            x:Name="OldPasswordBox"
            Background="Transparent"
            BorderThickness="0"
            FontSize="14"
            Foreground="{DynamicResource TitleTextBrush}"
            CaretBrush="{DynamicResource AccentBlueBrush}"
            Padding="12,10"
            GotFocus="OnPasswordBoxGotFocus"
            LostFocus="OnPasswordBoxLostFocus"
          >
            <PasswordBox.Template>
              <ControlTemplate TargetType="PasswordBox">
                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
              </ControlTemplate>
            </PasswordBox.Template>
          </PasswordBox>
        </Border>
        <!-- New Password -->
        <TextBlock
          Text="{DynamicResource LabelNewPassword}"
          FontSize="11"
          Foreground="{DynamicResource SecondaryTextBrush}"
          Margin="0,0,0,4"
        />
        <Border
          x:Name="NewPwBorder"
          Background="{DynamicResource InfoCardBgBrush}"
          CornerRadius="10"
          BorderThickness="1.5"
          BorderBrush="{DynamicResource DividerBrush}"
          Margin="0,0,0,14"
        >
          <PasswordBox
            x:Name="NewPasswordBox"
            Background="Transparent"
            BorderThickness="0"
            FontSize="14"
            Foreground="{DynamicResource TitleTextBrush}"
            CaretBrush="{DynamicResource AccentBlueBrush}"
            Padding="12,10"
            GotFocus="OnPasswordBoxGotFocus"
            LostFocus="OnPasswordBoxLostFocus"
          >
            <PasswordBox.Template>
              <ControlTemplate TargetType="PasswordBox">
                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
              </ControlTemplate>
            </PasswordBox.Template>
          </PasswordBox>
        </Border>
        <!-- Change Password button -->
        <Button
          Style="{DynamicResource GetButtonStyle}"
          HorizontalAlignment="Stretch"
          Command="{Binding ChangePasswordCommand}"
        >
          <TextBlock
            Text="{DynamicResource ChangePassword}"
            Foreground="{DynamicResource GetBtnTextBrush}"
            FontSize="13"
            FontWeight="SemiBold"
          />
        </Button>
      </StackPanel>
      <!-- ── Separator ─────────────────────────────────────── -->
      <Border Height="1" Background="{DynamicResource SeparatorBrush}" />
      <!-- ═══ Dark Mode Toggle Row ════════════════════════════ -->
      <Grid Margin="18,12,18,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <TextBlock
            Text="{DynamicResource DarkModeLabel}"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{DynamicResource TitleTextBrush}"
          />
          <TextBlock
            Text="{DynamicResource DarkModeHint}"
            FontSize="11"
            Foreground="{DynamicResource SecondaryTextBrush}"
            Margin="0,2,0,0"
          />
        </StackPanel>
        <ToggleButton
          Grid.Column="1"
          Style="{DynamicResource ToggleSwitchStyle}"
          IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
          VerticalAlignment="Center"
          Command="{Binding ToggleThemeCommand}"
        />
      </Grid>
      <!-- ── Separator ─────────────────────────────────────── -->
      <Border Height="1" Background="{DynamicResource SeparatorBrush}" />
      <!-- ═══ Logout ══════════════════════════════════════════ -->
      <Button
        Click="OnLogout"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand"
        Padding="18,12"
        HorizontalContentAlignment="Left"
      >
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="LogoutBd"
              Background="{TemplateBinding Background}"
              Padding="{TemplateBinding Padding}"
            >
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="LogoutBd" Property="Background" Value="#1AFF3B30" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="LogoutBd" Property="Background" Value="#33FF3B30" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Button.Template>
        <StackPanel Orientation="Horizontal">
          <TextBlock
            Text="→"
            FontSize="15"
            Foreground="{DynamicResource ErrorBrush}"
            Margin="0,0,8,0"
            VerticalAlignment="Center"
          />
          <TextBlock
            Text="{DynamicResource Logout}"
            FontSize="14"
            Foreground="{DynamicResource ErrorBrush}"
            VerticalAlignment="Center"
          />
        </StackPanel>
      </Button>
      <Border Height="4" />
    </StackPanel>
  </Border>
</Window>
