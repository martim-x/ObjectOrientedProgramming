<UserControl
  x:Class="Project.Views.AppDetailView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <Grid
    Visibility="{Binding SelectedApp, Converter={StaticResource NullToVis}}"
    Background="{DynamicResource WindowBgBrush}"
  >
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <!-- HEADER -->
    <Border
      Grid.Row="0"
      Padding="20,14,20,0"
      BorderThickness="0,0,0,1"
      BorderBrush="{DynamicResource DividerBrush}"
    >
      <StackPanel>
        <!-- Back -->
        <Button
          Style="{DynamicResource IconButtonStyle}"
          HorizontalAlignment="Left"
          Padding="0,0,0,10"
          Background="Transparent"
          Command="{Binding CloseDetailCommand}"
        >
          <StackPanel Orientation="Horizontal">
            <TextBlock
              Text="‹"
              FontSize="22"
              Foreground="{DynamicResource AccentBlueBrush}"
              Margin="0,-3,4,0"
              VerticalAlignment="Center"
            />
            <TextBlock
              Text="{DynamicResource Back}"
              FontSize="14"
              Foreground="{DynamicResource AccentBlueBrush}"
              VerticalAlignment="Center"
            />
          </StackPanel>
        </Button>
        <!-- Icon + Name + buttons row -->
        <Grid Margin="0,0,0,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <!-- Icon -->
          <Border
            Grid.Column="0"
            Width="72"
            Height="72"
            CornerRadius="16"
            Margin="0,0,16,0"
            Background="{Binding SelectedApp.Color, Converter={StaticResource ColorBrush}}"
          >
            <Border.Effect>
              <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.15" Color="#000000" />
            </Border.Effect>
            <TextBlock
              Text="{Binding SelectedApp.ShortName}"
              FontSize="14"
              FontWeight="Bold"
              Foreground="White"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="64"
              TextTrimming="CharacterEllipsis"
              TextAlignment="Center"
            />
          </Border>
          <!-- Name + categories -->
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock
              Text="{Binding SelectedApp.FullName}"
              FontSize="17"
              FontWeight="SemiBold"
              Foreground="{DynamicResource TitleTextBrush}"
              TextWrapping="Wrap"
            />
            <TextBlock
              Text="{Binding SelectedApp.Category}"
              FontSize="13"
              Foreground="{DynamicResource SecondaryTextBrush}"
              Margin="0,3,0,0"
            />
          </StackPanel>
          <!-- Edit/Delete button (pencil, Get-style) - only for admin -->
          <Button
            Grid.Column="2"
            VerticalAlignment="Center"
            Margin="10,0,8,0"
            Style="{DynamicResource GetButtonStyle}"
            Padding="12,6"
            Click="OnEditDeleteClick"
            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
          >
            <StackPanel Orientation="Horizontal">
              <TextBlock
                Text="✎"
                FontSize="13"
                Margin="0,0,5,0"
                Foreground="{DynamicResource GetBtnTextBrush}"
              />
              <TextBlock
                Text="{DynamicResource EditBtn}"
                FontSize="13"
                Foreground="{DynamicResource GetBtnTextBrush}"
              />
            </StackPanel>
          </Button>
          <!-- Install / Uninstall - Get or Open -->
          <Button
            Grid.Column="3"
            VerticalAlignment="Center"
            Margin="0,0,0,0"
            Style="{DynamicResource PrimaryButtonStyle}"
            Padding="18,6"
            Command="{Binding DownloadCommand}"
            CommandParameter="{Binding SelectedApp}"
          >
            <TextBlock FontSize="14">
              <TextBlock.Text>
                <MultiBinding Converter="{StaticResource ButtonLabelConv}">
                  <Binding Path="SelectedApp.IsDownloaded" />
                  <Binding Path="SelectedApp.Price" />
                  <Binding Path="CurrentLanguage" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </Button>
        </Grid>
        <!-- Divider -->
        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,0,0,12" />
        <!-- Info tiles: 5 tiles, uniform height via UniformGrid rows -->
        <UniformGrid Columns="5" Rows="1" Margin="0,0,0,12" Height="110">
          <!-- Tile 1: Ratings -->
          <Border Background="{DynamicResource InfoCardBgBrush}" CornerRadius="10" Margin="0,0,8,0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <!-- top label: "41K Ratings" in ONE line -->
              <StackPanel
                Grid.Row="0"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,2"
              >
                <TextBlock
                  Text="{Binding SelectedApp.RatingCount, Converter={StaticResource DlCountConv}}"
                  FontSize="10"
                  Foreground="{DynamicResource RatingCountBrush}"
                />
                <TextBlock Text=" " FontSize="10" />
                <TextBlock
                  Text="{DynamicResource TileRatings}"
                  FontSize="10"
                  Foreground="{DynamicResource RatingCountBrush}"
                />
              </StackPanel>
              <!-- big number -->
              <TextBlock
                Grid.Row="1"
                Text="{Binding SelectedApp.Rating, StringFormat={}{0:F1}}"
                FontSize="22"
                FontWeight="Bold"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
              />
              <!-- stars -->
              <TextBlock
                Grid.Row="2"
                Text="{Binding SelectedApp.Rating, Converter={StaticResource RatingStars}}"
                FontSize="10"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
              />
              <Border Grid.Row="3" />
            </Grid>
          </Border>
          <!-- Tile 2: Age -->
          <Border Background="{DynamicResource InfoCardBgBrush}" CornerRadius="10" Margin="0,0,8,0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock
                Grid.Row="0"
                Text="{DynamicResource TileAge}"
                FontSize="10"
                Foreground="{DynamicResource RatingCountBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,2"
              />
              <TextBlock
                Grid.Row="1"
                Text="{Binding SelectedApp.AgeRating}"
                FontSize="22"
                FontWeight="Bold"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
              />
              <TextBlock
                Grid.Row="2"
                Text="{DynamicResource TileYears}"
                FontSize="10"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
              />
              <Border Grid.Row="3" />
            </Grid>
          </Border>
          <!-- Tile 3: Developer -->
          <Border Background="{DynamicResource InfoCardBgBrush}" CornerRadius="10" Margin="0,0,8,0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock
                Grid.Row="0"
                Text="{DynamicResource TileDev}"
                FontSize="10"
                Foreground="{DynamicResource RatingCountBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,2"
              />
              <TextBlock
                Grid.Row="1"
                Text="{Binding SelectedApp.Developer}"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"
              />
              <TextBlock
                Grid.Row="2"
                Text="{DynamicResource TileDevLabel}"
                FontSize="10"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
              />
              <Border Grid.Row="3" />
            </Grid>
          </Border>
          <!-- Tile 4: Language -->
          <Border Background="{DynamicResource InfoCardBgBrush}" CornerRadius="10" Margin="0,0,8,0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock
                Grid.Row="0"
                Text="{DynamicResource TileLang}"
                FontSize="10"
                Foreground="{DynamicResource RatingCountBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,2"
              />
              <TextBlock
                Grid.Row="1"
                Text="EN"
                FontSize="22"
                FontWeight="Bold"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
              />
              <TextBlock
                Grid.Row="2"
                Text="+9 more"
                FontSize="10"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
              />
              <Border Grid.Row="3" />
            </Grid>
          </Border>
          <!-- Tile 5: Size — use SizeConv which returns "186.3 MB" -->
          <Border Background="{DynamicResource InfoCardBgBrush}" CornerRadius="10">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock
                Grid.Row="0"
                Text="{DynamicResource TileSize}"
                FontSize="10"
                Foreground="{DynamicResource RatingCountBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,2"
              />
              <TextBlock
                Grid.Row="1"
                Text="{Binding SelectedApp.SizeMB, Converter={StaticResource SizeConv}}"
                FontSize="16"
                FontWeight="Bold"
                Foreground="{DynamicResource RatingStarBrush}"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"
              />
              <Border Grid.Row="2" />
              <Border Grid.Row="3" />
            </Grid>
          </Border>
        </UniformGrid>
      </StackPanel>
    </Border>
    <!-- BODY -->
    <ScrollViewer Grid.Row="1" Padding="20,16,20,20" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock
          Text="{Binding SelectedApp.Description}"
          FontSize="14"
          Foreground="{DynamicResource TitleTextBrush}"
          TextWrapping="Wrap"
          LineHeight="22"
          Margin="0,0,0,20"
        />
        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,0,0,14" />
        <Grid Margin="0,0,0,20">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Text="{DynamicResource Developer}"
            Style="{DynamicResource CaptionStyle}"
            Margin="0,0,0,10"
          />
          <TextBlock
            Grid.Row="0"
            Grid.Column="1"
            Text="{Binding SelectedApp.Developer}"
            FontSize="13"
            Foreground="{DynamicResource TitleTextBrush}"
            Margin="0,0,0,10"
          />
          <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Text="{DynamicResource Version}"
            Style="{DynamicResource CaptionStyle}"
            Margin="0,0,0,10"
          />
          <TextBlock
            Grid.Row="1"
            Grid.Column="1"
            Text="{Binding SelectedApp.Version}"
            FontSize="13"
            Foreground="{DynamicResource TitleTextBrush}"
            Margin="0,0,0,10"
          />
          <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Text="{DynamicResource Country}"
            Style="{DynamicResource CaptionStyle}"
            Margin="0,0,0,10"
          />
          <TextBlock
            Grid.Row="2"
            Grid.Column="1"
            Text="{Binding SelectedApp.Country}"
            FontSize="13"
            Foreground="{DynamicResource TitleTextBrush}"
            Margin="0,0,0,10"
          />
          <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Text="{DynamicResource Price}"
            Style="{DynamicResource CaptionStyle}"
          />
          <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
            <TextBlock
              Text="{Binding SelectedApp.FinalPrice, Converter={StaticResource PriceConv}}"
              FontSize="13"
              FontWeight="SemiBold"
              Foreground="{DynamicResource AccentBlueBrush}"
            />
            <Border
              Background="#FF9500"
              CornerRadius="4"
              Padding="5,1"
              Margin="8,0,0,0"
              Visibility="{Binding SelectedApp.DiscountPercent, Converter={StaticResource DiscountVis}}"
            >
              <TextBlock
                Text="{Binding SelectedApp.DiscountPercent, StringFormat=-{0:F0}%}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
              />
            </Border>
          </StackPanel>
        </Grid>
        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,0,0,14" />
        <TextBlock
          Text="{DynamicResource Tags}"
          Style="{DynamicResource CaptionStyle}"
          Margin="0,0,0,8"
        />
        <ItemsControl ItemsSource="{Binding SelectedApp.Tags}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border
                Background="{DynamicResource GetBtnBgBrush}"
                CornerRadius="12"
                Padding="10,4"
                Margin="0,0,6,6"
              >
                <TextBlock
                  Text="{Binding}"
                  FontSize="11"
                  Foreground="{DynamicResource GetBtnTextBrush}"
                />
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Border Height="20" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>