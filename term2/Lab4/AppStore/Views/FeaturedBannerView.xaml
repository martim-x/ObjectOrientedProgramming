<UserControl x:Class="AppStore.Views.FeaturedBannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="16" Height="180" ClipToBounds="True" Cursor="Hand"
            MouseLeftButtonUp="OnBannerClick">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F4FD" Offset="0"/>
                <GradientStop Color="#D6EAFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.08" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource FeaturedToday}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding FeaturedApps[0].FullName, FallbackValue='Featured App'}"
                           FontSize="22" FontWeight="Bold" Foreground="{StaticResource TitleTextBrush}"
                           TextWrapping="Wrap" MaxWidth="360" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding FeaturedApps[0].Developer}"
                           FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,14"/>
                <Button Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left"
                        Command="{Binding OpenDetailCommand}" CommandParameter="{Binding FeaturedApps[0]}">
                    <TextBlock Text="{DynamicResource Download}" FontSize="13"/>
                </Button>
            </StackPanel>
            <Border Grid.Column="1" Width="100" Height="100" CornerRadius="22" Margin="0,0,8,0"
                    Background="{Binding FeaturedApps[0].Color, Converter={StaticResource ColorBrush}}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.25" Color="#000000"/>
                </Border.Effect>
                <TextBlock Text="{Binding FeaturedApps[0].ShortName}" FontSize="18" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                           MaxWidth="88" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
